
int* twoSum(int* numbers, int numbersSize, int target, int* returnSize) {
    int *arr = malloc(  2 * sizeof(int));
    int i=0, j = numbersSize-1;
    while(i<j)
    {
        int sum = numbers[i] + numbers[j];
        if(sum == target)
        {
            arr[0] = i+1;
            arr[1] = j+1;
            break;
        }
        else if(sum>target)
        j--;
        else
        i++;
    }
    *returnSize = 2;
    return arr;
}
