class Solution {
    public int[][] matrixReshape(int[][] mat, int r, int c) {
        
        int m = mat.length;
        int n = mat[0].length;

        int l = m*n;
        if((r*c)!=l)
        return mat;
        
        int[] arr = new int[l];

        int ptr = 0;
        for(int i=0;i<m;i++)
        {
            for(int j=0;j<n;j++)
            {
                arr[ptr++] = mat[i][j];
            }
        } //stored in 1D

        ptr = 0;
        int[][] arr1 = new int[r][c];
        //reshaping
        for(int i=0;i<r;i++)
        {
            for(int j=0;j<c;j++)
            {
                arr1[i][j] = arr[ptr++];
            }
        }
        return arr1;
    }
}
