class Solution {
    public boolean isTrionic(int[] nums) 
    {
        int tri = 1;
        if(!(nums[0]<(nums[1])))
        return false;

        for(int i=0;i<nums.length-1;i++)
        {
            if(nums[i]==nums[i+1])
            return false;
            
            if((nums[i]>(nums[i+1])) && tri==3)
            {
                return false;
            }
            else if((nums[i]>(nums[i+1])) && tri==2)
            {
                continue;
            }
            else if((nums[i]<(nums[i+1])) && (tri==1 || tri==3))
            {
                continue;
            }
            else if((nums[i]>(nums[i+1])) && tri==1)
            {
                tri++;
                continue;
            }
            else if((nums[i]<(nums[i+1])) && tri==2)
            {
                tri++;
                continue;
            }

            if(tri>3)
            return false;
        } 
          if(tri==3) return true;
          else return false; 
    }
}
