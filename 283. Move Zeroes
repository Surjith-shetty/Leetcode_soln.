void moveZeroes(int* nums, int numsSize) {
    int i,j;

    for(i=0,j=0;i<numsSize-1;)
    {
        if(i==j && nums[i]!=0)
        {
            i++;
            j++;
            continue;
        }

        if(nums[j]==0 && j<numsSize)
        {
            if(j==numsSize - 1)
            break;
            j++;
            continue;
        }

        if(nums[i]==0)
        {
            int temp = nums[j];
            nums[j] = nums[i];
            nums[i] = temp;
            i++;
        }
    }
}
