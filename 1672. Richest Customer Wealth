class Solution {
    public int maximumWealth(int[][] accounts) {
        int max = 0;
        int m = accounts.length;

        if(m==0)
        return 0;

        int n = accounts[0].length;
        int sum = 0;
        for(int i=0;i<m;i++)
        {
            sum = 0;
            for(int j=0;j<n;j++)
            {
                sum+=accounts[i][j];
            }
            max = (max>sum)?max:sum;
        }
        return max;
    }
}
